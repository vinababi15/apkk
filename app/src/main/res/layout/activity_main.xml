<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/topAppBar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/bg_header"
            app:title="@string/app_name"
            app:titleCentered="true"
            app:titleTextColor="#FFFFFF"
            app:titleTextAppearance="@style/Title.AppBar"
            app:navigationIcon="@android:drawable/ic_menu_sort_by_size"
            app:navigationIconTint="#FFFFFF" />

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipe"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:padding="16dp">

                    <!-- Share panel -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:paddingTop="20dp"
                        android:paddingBottom="20dp"
                        android:elevation="3dp"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/app_name"
                            android:textSize="20sp"
                            android:gravity="center"
                            android:textColor="?attr/colorOnSurface"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:layout_marginTop="2dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fill in the fields to start sharing."
                            android:textSize="12sp"
                            android:gravity="center"
                            android:fontFamily="sans-serif"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <EditText
                            android:id="@+id/inputCookie"
                            android:layout_marginTop="18dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_cookie"
                            android:background="@drawable/bg_input"
                            android:padding="12dp"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif"
                            android:textColor="?attr/colorOnSurface"
                            android:textColorHint="?attr/colorOnSurfaceVariant"
                            android:inputType="textMultiLine"
                            android:minLines="2"
                            android:maxLines="3" />

                        <EditText
                            android:id="@+id/inputLink"
                            android:layout_marginTop="10dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_link"
                            android:background="@drawable/bg_input"
                            android:padding="12dp"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif"
                            android:textColor="?attr/colorOnSurface"
                            android:textColorHint="?attr/colorOnSurfaceVariant"
                            android:inputType="textUri" />

                        <EditText
                            android:id="@+id/inputLimit"
                            android:layout_marginTop="10dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_limit"
                            android:background="@drawable/bg_input"
                            android:padding="12dp"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif"
                            android:textColor="?attr/colorOnSurface"
                            android:textColorHint="?attr/colorOnSurfaceVariant"
                            android:inputType="number" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnStart"
                            android:layout_marginTop="16dp"
                            android:layout_width="wrap_content"
                            android:layout_height="46dp"
                            android:minWidth="200dp"
                            android:text="@string/btn_start"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"
                            android:textAllCaps="false"
                            android:letterSpacing="0.04"
                            app:cornerRadius="14dp"
                            app:backgroundTint="@color/brand_primary" />

                        <ProgressBar
                            android:id="@+id/progressShare"
                            android:visibility="gone"
                            android:layout_marginTop="10dp"
                            android:layout_width="26dp"
                            android:layout_height="26dp" />
                    </LinearLayout>

                    <!-- Result card -->
                    <LinearLayout
                        android:id="@+id/resultCard"
                        android:visibility="gone"
                        android:layout_marginTop="14dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card"
                        android:padding="16dp"
                        android:elevation="3dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:id="@+id/resultIcon"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/ic_check_circle" />

                            <LinearLayout
                                android:layout_marginStart="12dp"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/resultTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Success"
                                    android:textSize="16sp"
                                    android:fontFamily="sans-serif-black"
                                    android:textColor="?attr/colorOnSurface" />

                                <TextView
                                    android:id="@+id/resultSubtitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Request completed"
                                    android:textSize="11sp"
                                    android:fontFamily="sans-serif"
                                    android:textColor="?attr/colorOnSurfaceVariant" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/resultBadge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="6dp"
                                android:paddingBottom="6dp"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-medium"
                                android:text="200 OK"
                                android:textColor="#16A34A"
                                android:background="@drawable/bg_pill_success" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/metricsRow"
                            android:layout_marginTop="14dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal" />

                        <TextView
                            android:id="@+id/resultMessage"
                            android:layout_marginTop="12dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:lineSpacingExtra="2dp"
                            android:fontFamily="sans-serif"
                            android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/drawer_menu" />
</androidx.drawerlayout.widget.DrawerLayout>
