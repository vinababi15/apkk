<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.FBShareBX" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryVariant">@color/brand_primary_dark</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">@color/brand_accent</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_dark</item>
        <item name="colorOnSurfaceVariant">#A8B0C2</item>
        <item name="android:statusBarColor" tools:targetApi="l">#0B1220</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
    </style>

    <style name="Theme.FBShareBX.Splash" parent="Theme.FBShareBX">
        <item name="android:windowBackground">@drawable/splash_bg</item>
        <item name="android:statusBarColor">#0B1220</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="Title.AppBar" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:textSize">18sp</item>
    </style>
</resources>
